{
  "compilerOptions": {
    "target": "ESNext",
    "skipLibCheck": true,
    "noImplicitAny": true,
    "allowJs": true,
    "checkJs": true,
    "strict": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "src",
    "moduleResolution": "bundler",
    "module": "preserve",
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "declaration": true,
    "declarationMap": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}